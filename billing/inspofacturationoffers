                          {selectedFacture.fixe > 0 && (
                            <tr className="border-t border-[#e8eaef]">
                              <td className="px-4 py-3.5">
                                <span className="text-[13px] font-medium text-[#1a1d2e]">Forfait mensuel</span>
                                <span className="text-[12px] text-[#8b8fa3] ml-2">— Abonnement {selectedFacture.periode}</span>
                              </td>
                              <td className="text-center px-4 py-3.5 text-[13px] text-[#1a1d2e]">1</td>
                              <td className="text-right px-4 py-3.5 text-[13px] text-[#1a1d2e]">{selectedFacture.fixe}€</td>
                              <td className="text-right px-4 py-3.5 text-[13px] font-semibold text-[#1a1d2e]">{selectedFacture.fixe}€</td>
                            </tr>
                          )}
                          {selectedFacture.nbRdv > 0 && (
                            <tr className="border-t border-[#e8eaef]">
                              <td className="px-4 py-3.5">
                                <span className="text-[13px] font-medium text-[#1a1d2e]">Rendez-vous qualifiés</span>
                                <span className="text-[12px] text-[#8b8fa3] ml-2">— {selectedFacture.periode}</span>
                              </td>
                              <td className="text-center px-4 py-3.5 text-[13px] text-[#1a1d2e]">{selectedFacture.nbRdv}</td>
                              <td className="text-right px-4 py-3.5 text-[13px] text-[#1a1d2e]">{selectedFacture.prixRdv}€</td>
                              <td className="text-right px-4 py-3.5 text-[13px] font-semibold text-[#1a1d2e]">{selectedFacture.variable}€</td>
                            </tr>
                          )}
                        </tbody>
                        <tfoot>
                          <tr className="border-t-2 border-[#e8eaef] bg-[#f8f9fb]">
                            <td colSpan={3} className="text-right px-4 py-3.5 text-[14px] font-bold text-[#1a1d2e]">Total HT</td>
                            <td className="text-right px-4 py-3.5 text-[16px] font-bold text-[#4f6ef7]">{selectedFacture.total.toLocaleString('fr-FR')}€</td>
                          </tr>
                        </tfoot>
                      </table>
                    </div>

                    {/* RDV Breakdown per Mission */}
                    {selectedFacture.nbRdv > 0 && (
                      <div className="mt-4">
                        <button onClick={handleToggleMissions} className="flex items-center gap-2 text-[13px] text-[#8b8fa3] hover:text-[#4f6ef7] font-medium transition-colors duration-150">
                          {expandedMissions ? <ChevronUp className="w-4 h-4" /> : <ChevronDown className="w-4 h-4" />}
                          Détail par mission ({FACTURE_MISSIONS.length} missions)
                        </button>
                        {expandedMissions && (
                          <div className="mt-3 border border-[#e8eaef] rounded-lg overflow-hidden">
                            {FACTURE_MISSIONS.map((m, i) => (
                              <div key={i} className={`flex items-center justify-between px-4 py-3 ${i > 0 ? 'border-t border-[#e8eaef]' : ''}`}>
                                <div>
                                  <span className="text-[13px] font-medium text-[#1a1d2e]">{m.mission}</span>
                                </div>
                                <div className="flex items-center gap-6">
                                  <span className="text-[13px] text-[#8b8fa3]">{m.rdvs} RDVs</span>
                                  <span className="text-[13px] font-semibold text-[#1a1d2e]">{m.montant}€</span>
                                </div>
                              </div>
                            ))}
                          </div>
                        )}
                      </div>
                    )}
                  </div>
                </div>

                {/* Right: Invoice Meta */}
                <div className="space-y-5">
                  <div className="bg-white rounded-xl border border-[#e8eaef] p-5">
                    <h3 className="text-[13px] font-bold text-[#8b8fa3] uppercase tracking-wider mb-4">Informations</h3>
                    <div className="space-y-3.5">
                      <div>
                        <div className="text-[11.5px] text-[#b0b4c5] uppercase font-semibold tracking-wider">Client</div>
                        <div className="text-[14px] font-medium text-[#1a1d2e] mt-0.5">{selectedFacture.client}</div>
                      </div>
                      <div>
                        <div className="text-[11.5px] text-[#b0b4c5] uppercase font-semibold tracking-wider">Période</div>
                        <div className="text-[14px] font-medium text-[#1a1d2e] mt-0.5">{selectedFacture.periode}</div>
                      </div>
                      <div>
                        <div className="text-[11.5px] text-[#b0b4c5] uppercase font-semibold tracking-wider">Date d'émission</div>
                        <div className="text-[14px] font-medium text-[#1a1d2e] mt-0.5">01/02/2025</div>
                      </div>
                      <div>
                        <div className="text-[11.5px] text-[#b0b4c5] uppercase font-semibold tracking-wider">Échéance</div>
                        <div className="text-[14px] font-medium text-[#1a1d2e] mt-0.5">01/03/2025</div>
                      </div>
                    </div>
                  </div>

                  <div className="bg-[#4f6ef7]/5 rounded-xl border border-[#4f6ef7]/15 p-5">
                    <div className="text-[12px] font-semibold text-[#4f6ef7] uppercase tracking-wider mb-1">Montant total</div>
                    <div className="text-[28px] font-bold text-[#4f6ef7] tracking-tight">{selectedFacture.total.toLocaleString('fr-FR')}€</div>
                    <div className="text-[12px] text-[#8b8fa3] mt-1">HT · TVA non applicable</div>
                  </div>

                  <div className="bg-white rounded-xl border border-[#e8eaef] p-5">
                    <h3 className="text-[13px] font-bold text-[#8b8fa3] uppercase tracking-wider mb-3">Actions rapides</h3>
                    <div className="space-y-2">
                      <button className="w-full flex items-center gap-2.5 px-3.5 py-2.5 text-[13px] font-medium text-[#1a1d2e] rounded-lg border border-[#e8eaef] hover:bg-[#f4f5f8] transition-colors duration-150">
                        <Download className="w-4 h-4 text-[#8b8fa3]" />
                        Télécharger PDF
                      </button>
                      <button className="w-full flex items-center gap-2.5 px-3.5 py-2.5 text-[13px] font-medium text-[#1a1d2e] rounded-lg border border-[#e8eaef] hover:bg-[#f4f5f8] transition-colors duration-150">
                        <Mail className="w-4 h-4 text-[#8b8fa3]" />
                        Envoyer par email
                      </button>
                      <button className="w-full flex items-center gap-2.5 px-3.5 py-2.5 text-[13px] font-medium text-[#1a1d2e] rounded-lg border border-[#e8eaef] hover:bg-[#f4f5f8] transition-colors duration-150">
                        <FileText className="w-4 h-4 text-[#8b8fa3]" />
                        Avoir / Crédit
                      </button>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          )}
        </div>
      </main>

      {/* ========== OFFRE MODAL ========== */}
      {showOffreModal && (
        <div className="fixed inset-0 bg-black/40 flex items-center justify-center z-50">
          <div className="bg-white rounded-2xl shadow-2xl w-[520px] max-h-[90vh] overflow-y-auto">
            <div className="flex items-center justify-between px-6 py-5 border-b border-[#e8eaef]">
              <h2 className="text-[17px] font-bold text-[#1a1d2e]">{editingOffre ? 'Modifier l\'offre' : 'Nouvelle offre'}</h2>
              <button onClick={handleCloseOffreModal} className="p-1.5 rounded-lg text-[#8b8fa3] hover:bg-[#f4f5f8] transition-colors duration-150">
                <X className="w-5 h-5" />
              </button>
            </div>
            <div className="px-6 py-5 space-y-5">
              <div>
                <label className="block text-[13px] font-semibold text-[#1a1d2e] mb-1.5">Nom de l'offre</label>
                <input
                  defaultValue={editingOffre ? editingOffre.nom : ''}
                  placeholder="Ex: Pack Standard"
                  className="w-full px-3.5 py-2.5 text-[14px] border border-[#e8eaef] rounded-lg outline-none focus:border-[#4f6ef7] transition-colors duration-150 placeholder-[#b0b4c5]"
                />
              </div>
              <div>
                <label className="block text-[13px] font-semibold text-[#1a1d2e] mb-1.5">Description</label>
                <textarea
                  defaultValue={editingOffre ? editingOffre.description : ''}
                  placeholder="Brève description de l'offre"
                  rows={2}
                  className="w-full px-3.5 py-2.5 text-[14px] border border-[#e8eaef] rounded-lg outline-none focus:border-[#4f6ef7] transition-colors duration-150 resize-none placeholder-[#b0b4c5]"
                />
              </div>
              <div className="grid grid-cols-2 gap-4">
                <div>
                  <label className="block text-[13px] font-semibold text-[#1a1d2e] mb-1.5">Forfait mensuel (€)</label>
                  <input
                    type="number"
                    defaultValue={editingOffre ? editingOffre.fixe : ''}
                    placeholder="0"
                    className="w-full px-3.5 py-2.5 text-[14px] border border-[#e8eaef] rounded-lg outline-none focus:border-[#4f6ef7] transition-colors duration-150 placeholder-[#b0b4c5]"
                  />
                  <span className="text-[11px] text-[#8b8fa3] mt-1 block">Laisser 0 si pas de forfait</span>
                </div>
                <div>
                  <label className="block text-[13px] font-semibold text-[#1a1d2e] mb-1.5">Prix par RDV (€)</label>
                  <input
                    type="number"
                    defaultValue={editingOffre ? editingOffre.rdv : ''}
                    placeholder="0"
                    className="w-full px-3.5 py-2.5 text-[14px] border border-[#e8eaef] rounded-lg outline-none focus:border-[#4f6ef7] transition-colors duration-150 placeholder-[#b0b4c5]"
                  />
                  <span className="text-[11px] text-[#8b8fa3] mt-1 block">Laisser 0 si pas de variable</span>
                </div>
              </div>
            </div>
            <div className="flex items-center justify-end gap-3 px-6 py-4 border-t border-[#e8eaef]">
              <button onClick={handleCloseOffreModal} className="px-4 py-2.5 text-[13px] font-medium text-[#8b8fa3] hover:text-[#1a1d2e] transition-colors duration-150">
                Annuler
              </button>
              <button className="px-5 py-2.5 text-[13px] font-semibold text-white bg-[#4f6ef7] rounded-lg hover:bg-[#3d5ce5] transition-colors duration-150 shadow-sm">
                {editingOffre ? 'Enregistrer' : 'Créer l\'offre'}
              </button>
            </div>
          </div>
        </div>
      )}

      {/* ========== ENGAGEMENT MODAL ========== */}
      {showEngagementModal && (
        <div className="fixed inset-0 bg-black/40 flex items-center justify-center z-50">
          <div className="bg-white rounded-2xl shadow-2xl w-[580px] max-h-[90vh] overflow-y-auto">
            <div className="flex items-center justify-between px-6 py-5 border-b border-[#e8eaef]">
              <h2 className="text-[17px] font-bold text-[#1a1d2e]">Nouvel engagement</h2>
              <button onClick={handleCloseEngagementModal} className="p-1.5 rounded-lg text-[#8b8fa3] hover:bg-[#f4f5f8] transition-colors duration-150">
                <X className="w-5 h-5" />
              </button>
            </div>
            <div className="px-6 py-5 space-y-5">
              <div>
                <label className="block text-[13px] font-semibold text-[#1a1d2e] mb-1.5">Client</label>
                <select className="w-full px-3.5 py-2.5 text-[14px] border border-[#e8eaef] rounded-lg outline-none focus:border-[#4f6ef7] transition-colors duration-150 bg-white text-[#1a1d2e]">
                  <option value="">Sélectionner un client</option>
                  <option>Nextera Solutions</option>
                  <option>DataFlow SAS</option>
                  <option>GreenTech Industries</option>
                </select>
              </div>
              <div>
                <label className="block text-[13px] font-semibold text-[#1a1d2e] mb-1.5">Offre tarifaire</label>
                <select className="w-full px-3.5 py-2.5 text-[14px] border border-[#e8eaef] rounded-lg outline-none focus:border-[#4f6ef7] transition-colors duration-150 bg-white text-[#1a1d2e]">
                  <option value="">Sélectionner une offre</option>
                  <option>Pack Standard — 600€ + 80€/rdv</option>
                  <option>Pack Premium — 1 200€ + 60€/rdv</option>
                  <option>Performance Pure — 120€/rdv</option>
                  <option>Forfait Fixe — 900€</option>
                </select>
              </div>
              <div className="p-4 rounded-lg bg-amber-50 border border-amber-200">
                <div className="flex items-center gap-2 mb-3">
                  <Edit2 className="w-4 h-4 text-amber-600" />
                  <span className="text-[13px] font-semibold text-amber-800">Personnaliser le tarif</span>
                </div>
                <div className="grid grid-cols-2 gap-4">
                  <div>
                    <label className="block text-[12px] font-medium text-amber-700 mb-1">Forfait mensuel (€)</label>
                    <input
                      type="number"
                      placeholder="Tarif de base"
                      className="w-full px-3 py-2 text-[14px] border border-amber-200 rounded-lg bg-white outline-none focus:border-amber-400 transition-colors duration-150 placeholder-[#b0b4c5]"
                    />
                  </div>
                  <div>
                    <label className="block text-[12px] font-medium text-amber-700 mb-1">Prix par RDV (€)</label>
                    <input
                      type="number"
                      placeholder="Tarif de base"
                      className="w-full px-3 py-2 text-[14px] border border-amber-200 rounded-lg bg-white outline-none focus:border-amber-400 transition-colors duration-150 placeholder-[#b0b4c5]"
                    />
                  </div>
                </div>
                <span className="text-[11px] text-amber-600 mt-2 block">Laissez vide pour utiliser le tarif de base de l'offre</span>
              </div>
              <div className="grid grid-cols-2 gap-4">
                <div>
                  <label className="block text-[13px] font-semibold text-[#1a1d2e] mb-1.5">Durée (mois)</label>
                  <select className="w-full px-3.5 py-2.5 text-[14px] border border-[#e8eaef] rounded-lg outline-none focus:border-[#4f6ef7] transition-colors duration-150 bg-white text-[#1a1d2e]">
                    <option value="3">3 mois</option>
                    <option value="6">6 mois</option>
                    <option value="12">12 mois</option>
                  </select>
                </div>
                <div>
                  <label className="block text-[13px] font-semibold text-[#1a1d2e] mb-1.5">Date de début</label>
                  <input
                    type="date"
                    className="w-full px-3.5 py-2.5 text-[14px] border border-[#e8eaef] rounded-lg outline-none focus:border-[#4f6ef7] transition-colors duration-150 text-[#1a1d2e]"
                  />
                </div>
              </div>
              <div>
                <label className="block text-[13px] font-semibold text-[#1a1d2e] mb-1.5">Pénalité de résiliation</label>
                <input
                  type="text"
                  placeholder="Ex: 2 mois de forfait"
                  className="w-full px-3.5 py-2.5 text-[14px] border border-[#e8eaef] rounded-lg outline-none focus:border-[#4f6ef7] transition-colors duration-150 placeholder-[#b0b4c5]"
                />
              </div>
            </div>
            <div className="flex items-center justify-end gap-3 px-6 py-4 border-t border-[#e8eaef]">
              <button onClick={handleCloseEngagementModal} className="px-4 py-2.5 text-[13px] font-medium text-[#8b8fa3] hover:text-[#1a1d2e] transition-colors duration-150">
                Annuler
              </button>
              <button className="px-5 py-2.5 text-[13px] font-semibold text-white bg-[#4f6ef7] rounded-lg hover:bg-[#3d5ce5] transition-colors duration-150 shadow-sm">
                Créer l'engagement
              </button>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}

export default App;